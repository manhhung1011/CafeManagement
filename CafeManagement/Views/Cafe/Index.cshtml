@model List<CafeManagement.Models.CafeItem>

@{
    ViewData["Title"] = "Danh sách món";
}

<h2>Danh sách món quán cà phê</h2>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success">
        @TempData["Message"]
    </div>
}

<form method="get" class="mb-3 d-flex">
    <input type="text" name="search" class="form-control me-2" placeholder="Tìm theo tên hoặc loại món" />
    <button type="submit" class="btn btn-primary">Tìm kiếm</button>
</form>

<a href="/Cafe/Create" class="btn btn-success mb-3">Thêm món mới</a>
<a href="/Cafe?sortOrder=@ViewBag.PriceSort" class="btn btn-secondary mb-3">Sắp xếp theo giá</a>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>Hiển thị trang @ViewBag.Page của @ViewBag.TotalPages (@ViewBag.TotalCount món)</div>
    <nav>
        <ul class="pagination mb-0">
            @{
                var current = (int)ViewBag.Page;
                var total = (int)ViewBag.TotalPages;
                var searchQuery = (string)ViewContext.HttpContext.Request.Query["search"];
                var sortQuery = (string)ViewContext.HttpContext.Request.Query["sortOrder"];
            }

            <li class="page-item @(current == 1 ? "disabled" : "")">
                <a class="page-link" href="@Url.Action("Index", "Cafe", new { page = current - 1, pageSize = ViewBag.PageSize, search = searchQuery, sortOrder = sortQuery })">«</a>
            </li>

            @for (int i = 1; i <= total; i++)
            {
                <li class="page-item @(i == current ? "active" : "")">
                    <a class="page-link" href="@Url.Action("Index", "Cafe", new { page = i, pageSize = ViewBag.PageSize, search = searchQuery, sortOrder = sortQuery })">@i</a>
                </li>
            }

            <li class="page-item @(current == total ? "disabled" : "")">
                <a class="page-link" href="@Url.Action("Index", "Cafe", new { page = current + 1, pageSize = ViewBag.PageSize, search = searchQuery, sortOrder = sortQuery })">»</a>
            </li>
        </ul>
    </nav>
</div>

@if (Model.Count == 0)
{
    <p>Chưa có dữ liệu</p>
}
else
{
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Id</th>
                <th>Tên món</th>
                <th>Loại</th>
                <th>Giá</th>
                <th>Số lượng</th>
                <th>Chức năng</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.Name</td>
                    <td>@item.Category</td>
                    <td>@item.Price.ToString("N0") VNĐ</td>
                    <td>@item.Quantity</td>
                    <td>
                        <a href="/Cafe/Detail/@item.Id" class="btn btn-info btn-sm">Chi tiết</a>
                        <a href="/Cafe/Edit/@item.Id" class="btn btn-warning btn-sm">Sửa</a>
                        <a href="/Cafe/Delete/@item.Id" class="btn btn-danger btn-sm">Xóa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@section Scripts {
    <script>
        console.log("Trang danh sách món đã được tải");
    </script>
}